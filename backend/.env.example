# CreditLens AI API — environment variables (all optional; sensible defaults apply).
# Copy to `.env` and adjust as needed. Prefix is CREDITLENS_.

CREDITLENS_APP_NAME=CreditLens AI API
CREDITLENS_APP_VERSION=1.0.0
CREDITLENS_LOG_LEVEL=INFO

# Directory holding the frozen production artifacts
# CREDITLENS_MODEL_DIR=backend/models

# Risk-category thresholds on the 0-100 risk score
CREDITLENS_MEDIUM_RISK_THRESHOLD=40
CREDITLENS_HIGH_RISK_THRESHOLD=70

# ---- Supabase persistence (optional) ----
# Leave blank to run without a database (assessments stay in browser localStorage only).
# Get these from Supabase: Project Settings -> API. Run backend/db/schema.sql once first.
SUPABASE_URL=
SUPABASE_KEY=
# Table name (defaults to "assessments")
# SUPABASE_TABLE=assessments

# ---- pgvector similarity search (optional) ----
# Turn on ONLY after running backend/db/pgvector.sql in Supabase.
# When false, embeddings are not stored and /assessments/similar returns 503.
ENABLE_VECTOR_SEARCH=false

# ---- LLM for underwriting memos ----
# Local: LLM_PROVIDER=ollama (default), LLM_MODEL=qwen3:4b, needs Ollama running.
# Cloud: LLM_PROVIDER=groq, LLM_MODEL=llama-3.3-70b-versatile, GROQ_API_KEY=<free key from console.groq.com>
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b
GROQ_API_KEY=
